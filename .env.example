# Local development environment for meops.
# Copy this file to .env.local or export the variables in your shell.

# Fine-grained GitHub token for repo discovery and repository visibility sync.
MEOPS_GITHUB_TOKEN=

# Optional comma-separated repo allowlist for discovery.
# Example: CraigWatt/meops,CraigWatt/vfo,CraigWatt/craig-watt-website
MEOPS_REPO_ALLOWLIST=

# Optional caps for discovery runs.
MEOPS_REPO_DISCOVERY_LIMIT=50
MEOPS_GITHUB_COMMIT_LIMIT=20
